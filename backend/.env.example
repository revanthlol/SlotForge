# --- App ---
APP_ENV=development
API_PORT=8000
DEV_MODE=false
FRONTEND_ORIGIN=http://localhost:5173
# Comma-separated list. Overrides FRONTEND_ORIGIN when set.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key_here
SUPABASE_SECRET_KEY=sb_secret_your_secret_key_here
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/jwt/v1/jwks

# --- Database (Supabase Postgres connection string) ---
# Direct port 5432 for migrations
DATABASE_URL=postgresql+psycopg://postgres:password@127.0.0.1:5432/slotforge
# Pooled port 6543 for application runtime
DATABASE_URL_POOLED=postgresql+psycopg://postgres:password@127.0.0.1:6543/slotforge

# --- Redis (local docker-compose by default) ---
REDIS_URL=redis://localhost:6379/0

# --- Premium AI review (Phase 8) ---
LLM_API_KEY=
LLM_MODEL=
